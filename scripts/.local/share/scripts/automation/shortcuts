#!/bin/zsh

# Regenerates directory- and file-shortcut keymaps for zsh, ranger, lf and nvim
# from two hand-edited data files. Source of truth: THIS script plus sf/sd below.
# To add a target: define its <name>_dir and <name>_file awk programs, then add one
# gen() call in the "Generate" section (comment-char, esc flag, envsubst flag).

# Config: source-of-truth data files (columns: <shortcut-name> <target-path>)
GENERAL_PATH="${DOTFILES:-$HOME/.dotfiles}/general/.config"
NVIM_PATH="${DOTFILES:-$HOME/.dotfiles}/nvim/.config/nvim"
ZSH_PATH="${DOTFILES:-$HOME/.dotfiles}/zsh/.config/zsh"
folders="$GENERAL_PATH/shortcuts/sd" # directory shortcuts
files="$GENERAL_PATH/shortcuts/sf"   # dotfile shortcuts

# Output locations
shellrc="$ZSH_PATH/.zshrc"
shell_shortcuts="$ZSH_PATH/.auto_aliases"
ranger_shortcuts="$GENERAL_PATH/ranger/shortcuts.conf"
lf_shortcuts="$GENERAL_PATH/lf/shortcuts"
nvim_shortcuts="$NVIM_PATH/lua/shortcuts.lua"

banner="AUTO GENERATED FILE, DO NOT MODIFY MANUALLY, UPDATE THE $(basename "$0") script"

# print message to stderr
warn() { print -u2 "shortcuts: $1"; }

# Preflight (fail loud): envsubst drives the ranger/lf/nvim targets; a missing
# gettext on a fresh machine would otherwise emit silently-empty keymaps.
command -v envsubst >/dev/null || {
	warn "envsubst missing (install gettext)"
	exit 1
}
for f in "$folders" "$files"; do
	[[ -r $f ]] || {
		warn "cannot read $f"
		exit 1
	}
	# duplicate names silently produce last-wins aliases; surface them
	dup=$(sed '/^#/d; /^$/d' "$f" | awk '{print $1}' | sort | uniq -d)
	[[ -n $dup ]] && warn "duplicate names in $f: ${dup//$'\n'/ }"
done
# Referenced env vars that are unset expand to empty; those shortcuts get skipped.
unset_vars=$(grep -hoE '\$[A-Za-z_][A-Za-z0-9_]*' "$folders" "$files" | sort -u |
	while read -r v; do [[ -z ${(P)v[2,-1]} ]] && print -- "$v"; done)
[[ -n $unset_vars ]] && warn "unset vars (their shortcuts are skipped): ${unset_vars//$'\n'/ }"

# Make each config source its generated file, once.
grep -qF '. $ZDOTDIR/.auto_aliases' "$shellrc" ||
	echo '[[ -f "$ZDOTDIR/.auto_aliases" ]] && . $ZDOTDIR/.auto_aliases' >>"$shellrc"
grep -qF "source $ranger_shortcuts" "$GENERAL_PATH/ranger/rc.conf" ||
	echo "source $ranger_shortcuts" >>"$GENERAL_PATH/ranger/rc.conf"
grep -qF "source $lf_shortcuts" "$GENERAL_PATH/lf/lfrc" ||
	echo "source $lf_shortcuts" >>"$GENERAL_PATH/lf/lfrc"

# Shared awk helper. p() joins a shortcut's path fields: a `tmux` keyword in field 2
# (e.g. "xx tmux $WORK") is skipped so fields 3..NF form the path, otherwise 2..NF.
# esc=1 escapes spaces as `\ ` (shell/nvim want escaped, ranger/lf want plain).
# The p()=="" rule drops any shortcut whose path expanded to empty (an unset var),
# so a stale entry never emits a broken `cd ` / cwd='' keymap.
awklib='function p(  s,i,sep){sep=(esc?"\\ ":" ");s="";for(i=($2=="tmux"?3:2);i<=NF;i++)s=(s==""?$i:s sep $i);return s}
p()==""{next}'

# Emit programs: one per (target, data-kind). *_dir consumes sd, *_file consumes sf.
# Only the shell dir alias acts on the tmux keyword (opens via tmuxcd); others just cd.
shell_dir='{if($2=="tmux")print "alias "$1"=\047tmuxcd "p()"\047";else print "alias "$1"=\047cd "p()" && ls -a\047"}'
ranger_dir='{s=p();print "map <backspace>"$1" cd "s"\nmap t"$1" tab_new "s"\nmap m"$1" shell mv -v %s "s"\nmap Y"$1" shell cp -rv %s "s}'
lf_dir='{s=p();print "map <backspace2>"$1" cd "s"\nmap m"$1" $ mv -v $f "s"\nmap Y"$1" $ cp -rv $f "s}'

shell_file='{print "alias "$1"=\"$EDITOR "p()"\""}'
ranger_file='{print "map <backspace>"$1" shell $EDITOR "p()}'
lf_file='{print "map <backspace2>"$1" $ $EDITOR "p()}'

# tmuxcd backs the `tmux` keyword shortcuts. Emitted into .auto_aliases so the
# generated file is self-contained and needs nothing from .aliases at runtime.
shell_preamble='tmuxcd() {
  local dir=$1
  local name
  name=$(basename "$dir")
  name=${name//[.: ]/_} # tmux forbids . and : in session names
  tmux new-session -d -s "$name" -c "$dir" 2>/dev/null
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$name"
  else
    tmux attach -t "$name"
  fi
}'

# nvim: three keymaps per dir shortcut (edit, telescope find_files, telescope grep_string).
# grep_string can exact-match with a single quote; see telescope-fzf-native docs.
nvim_open='{shortcut=p()}{print"'
nvim_edit='vim.keymap.set(\"n\", \"<backspace>"$1"\", \"<cmd>e "shortcut"<cr>\", {silent=true, noremap=true})\n'
nvim_find='vim.keymap.set(\"n\",\"<backspace><a-p>"$1"\", \":lua require('\''telescope.builtin'\'').find_files({prompt_title = '\''<"shortcut">'\'', cwd = '\''"shortcut"'\'', hidden = '\''true'\''})<cr>\", { noremap = true, silent = true })\n'
nvim_grep='vim.keymap.set(\"n\",\"<backspace><a-r>"$1"\", \":lua require('\''telescope.builtin'\'').grep_string({prompt_title = '\''<LIVE GREP "shortcut">'\'', cwd = '\''"shortcut"'\'', search ='\'''\'',  shorten_path = true})<cr>\", { noremap = true, silent = true })\n'
nvim_close='"}'
nvim_dir="$nvim_open$nvim_edit$nvim_find$nvim_grep$nvim_close"
nvim_file='{print "vim.keymap.set(\"n\", \"<backspace>"$1"\", \"<cmd>e "p()" <cr>\", {silent=true, noremap=true})"}'

# gen <outfile> <comment-char> <esc 0|1> <envsubst 0|1> <dir_prog> <file_prog>
# Writes the banner (truncating any old content), then appends the sd and sf passes.
# envsubst expands $VARS at generation time; nvim needs it too because telescope's
# cwd is a literal string that neither :edit nor libuv expand. Shell keeps vars
# unexpanded (esc=1, envsubst=0) so $WORK etc. resolve at runtime.
gen() {
	local out=$1 cmt=$2 esc=$3 sub=$4 dprog=$5 fprog=$6 preamble=$7
	local expand=(cat)
	((sub)) && expand=(envsubst)
	printf "%s %s\n\n" "$cmt" "$banner" >"$out"
	[[ -n $preamble ]] && printf '%s\n\n' "$preamble" >>"$out"
	sed '/^#/d; /^$/d' "$folders" | $expand | awk -v esc=$esc "$awklib$dprog" >>"$out"
	sed '/^#/d; /^$/d' "$files" | $expand | awk -v esc=$esc "$awklib$fprog" >>"$out"
}

# Generate. Shell aliases are sourced by every login shell, so generate to a temp,
# syntax-check with `zsh -n`, and only move into place on success: a bad generation
# can never break shell startup.
gen "$ranger_shortcuts" "#" 0 1 "$ranger_dir" "$ranger_file"
gen "$lf_shortcuts" "#" 0 1 "$lf_dir" "$lf_file"
gen "$nvim_shortcuts" "--" 1 1 "$nvim_dir" "$nvim_file"

shell_tmp=$(mktemp)
gen "$shell_tmp" "#" 1 0 "$shell_dir" "$shell_file" "$shell_preamble"
if zsh -n "$shell_tmp"; then
	mv "$shell_tmp" "$shell_shortcuts"
else
	warn "generated aliases failed 'zsh -n'; keeping previous $shell_shortcuts"
	rm -f "$shell_tmp"
	exit 1
fi
