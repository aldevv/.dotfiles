#!/usr/bin/env bash
# tmux-claude-title2 <pane-pid>
# Print a 1-2 word kebab-case summary of the claude session running in the
# given tmux pane, by reading the session JSONL directly. Use this when
# Claude Code's pane_title is the static literal "Claude Code" (current
# behavior on macOS) so summarizing pane_title produces "claude-code"
# instead of a real summary.
#
# Resolution:
#   pane_pid -> claude descendant PID -> PWD env -> ~/.claude/projects/<mangled-pwd>/
#   -> jsonl whose first user-message timestamp is closest to (and not before)
#      the claude process start time -> first user message -> sha1 cache
#   -> claude -p summary

set -u

pane_pid="${1-}"
[ -z "$pane_pid" ] && exit 0

# Walk descendants of pane_pid via plain ps (pgrep -P is unreliable on macOS).
# Returns one PID per line.
descendants() {
    local root="$1"
    local snapshot
    snapshot=$(ps -axo pid=,ppid= 2>/dev/null) || return
    local stack=("$root")
    while [ ${#stack[@]} -gt 0 ]; do
        local pid="${stack[0]}"
        stack=("${stack[@]:1}")
        echo "$pid"
        local kids
        kids=$(printf '%s\n' "$snapshot" | awk -v p="$pid" '$2==p {print $1}')
        for k in $kids; do stack+=("$k"); done
    done
}

claude_pid=""
for pid in $(descendants "$pane_pid"); do
    [ "$pid" = "$pane_pid" ] && continue
    comm=$(ps -o comm= -p "$pid" 2>/dev/null) || continue
    base="${comm##*/}"
    case "$base" in
        claude|[0-9]*.[0-9]*.[0-9]*) claude_pid="$pid"; break ;;
    esac
done

[ -z "$claude_pid" ] && exit 0

# Pull PWD from the claude process env. ps eww outputs args + env on one line.
env_blob=$(ps eww -p "$claude_pid" -o command= 2>/dev/null) || exit 0
pwd_val=$(printf '%s\n' "$env_blob" | tr ' ' '\n' | awk -F= '$1=="PWD"{print substr($0,5); exit}')
[ -z "$pwd_val" ] && exit 0

mangled=$(printf '%s' "$pwd_val" | tr / -)
proj_dir="$HOME/.claude/projects/${mangled}"
[ -d "$proj_dir" ] || exit 0

# Map this pane's claude_pid to its own jsonl. Plain `ls -t` picks the same
# jsonl for every pane sharing a cwd, so all windows end up with the title of
# whichever session was last active. Match by the earliest user-message
# timestamp at-or-after the claude process start time: for fresh sessions
# that's the session's first message, for resumed (`claude -c`) sessions it's
# the first new message after resume. Either way the smallest delta wins.
proc_start_epoch=$(ps -o lstart= -p "$claude_pid" 2>/dev/null \
    | awk '{$1=$1; print}' \
    | xargs -I{} date -j -f "%a %b %e %T %Y" "{}" "+%s" 2>/dev/null)

if [ -z "$proc_start_epoch" ]; then
    jsonl=$(ls -t "$proj_dir"/*.jsonl 2>/dev/null | head -1)
    [ -z "$jsonl" ] || [ ! -f "$jsonl" ] && exit 0
    first_user=$(grep -m1 '"type":"user"' "$jsonl" 2>/dev/null | python3 -c '
import json, sys
try:
    d = json.loads(sys.stdin.read())
    msg = d.get("message", {})
    content = msg.get("content", "")
    if isinstance(content, list):
        for c in content:
            if isinstance(c, dict) and c.get("type") == "text":
                content = c.get("text", "")
                break
        else:
            content = ""
    if isinstance(content, str):
        sys.stdout.write(content)
except Exception:
    pass
' 2>/dev/null)
else
    first_user=$(python3 - "$proj_dir" "$proc_start_epoch" <<'PY' 2>/dev/null
import json, os, sys
from datetime import datetime, timezone
proj_dir, proc_start = sys.argv[1], int(sys.argv[2])
def parse_ts(s):
    try: return datetime.fromisoformat(s.replace("Z", "+00:00")).timestamp()
    except Exception: return None
def text_of(msg):
    c = msg.get("content", "") if isinstance(msg, dict) else ""
    if isinstance(c, list):
        for b in c:
            if isinstance(b, dict) and b.get("type") == "text":
                return b.get("text", "")
        return ""
    return c if isinstance(c, str) else ""
best = (10**9, "")
for name in os.listdir(proj_dir):
    if not name.endswith(".jsonl"): continue
    path = os.path.join(proj_dir, name)
    try:
        with open(path) as f:
            for line in f:
                try: d = json.loads(line)
                except Exception: continue
                if d.get("type") != "user": continue
                ts = parse_ts(d.get("timestamp", ""))
                if ts is None or ts < proc_start - 5: continue
                delta = abs(int(ts) - proc_start)
                if delta < best[0]:
                    best = (delta, text_of(d.get("message", {})))
                break
    except Exception: continue
sys.stdout.write(best[1] or "")
PY
)
fi

[ -z "$first_user" ] && exit 0

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/tmux-claude-title2"
mkdir -p "$cache_dir"

key=$(printf '%s' "$first_user" | shasum -a 1 2>/dev/null | cut -c1-16)
[ -z "$key" ] && exit 0
cache_file="$cache_dir/$key"

if [ -s "$cache_file" ]; then
    cat "$cache_file"
    exit 0
fi

# Synchronous fallback while the background summary lands: take the first
# meaningful word(s) of the user's first message, up to 3.
fallback=$(printf '%s' "$first_user" \
    | head -c 120 \
    | tr 'A-Z' 'a-z' \
    | tr -c 'a-z0-9 ' ' ' \
    | awk '{
        n=0; out="";
        for (i=1; i<=NF && n<3; i++) {
            if (length($i) >= 3) {
                out = (out=="" ? $i : out"-"$i);
                n++;
            }
        }
        if (out=="" && NF>0) out=$1;
        print out;
      }' \
    | sed -E 's/[^a-z0-9-]//g; s/^-+//; s/-+$//')
[ -z "$fallback" ] && fallback="claude"
printf '%s' "$fallback"

command -v claude >/dev/null 2>&1 || exit 0

if command -v timeout >/dev/null 2>&1; then
    timeout_cmd=(timeout 30)
elif command -v gtimeout >/dev/null 2>&1; then
    timeout_cmd=(gtimeout 30)
else
    timeout_cmd=()
fi

(
    lockdir="$cache_dir/$key.lockdir"
    mkdir "$lockdir" 2>/dev/null || exit 0
    trap 'rmdir "$lockdir" 2>/dev/null' EXIT

    prompt="Summarize this user request in 1 to 5 lowercase words, joined with '-' (no spaces). Use as few words as possible while still describing the task. Output ONLY the summary token, no quotes, no period, no explanation. Request: $first_user"
    out=$("${timeout_cmd[@]}" claude -p "$prompt" 2>/dev/null \
        | head -n1 \
        | tr -d '\r\n' \
        | tr 'A-Z' 'a-z' \
        | sed -E 's/[^a-z0-9-]//g; s/^-+//; s/-+$//')

    if printf '%s' "$out" | grep -qE '^[a-z0-9]+(-[a-z0-9]+){0,4}$'; then
        printf '%s' "$out" > "$cache_file"
        tmux refresh-client -S 2>/dev/null || true
    fi
) </dev/null >/dev/null 2>&1 &

disown 2>/dev/null || true
exit 0
