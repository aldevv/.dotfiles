#!/usr/bin/env bash
# Centered floating hunk diff of the repo the current tmux window is working on.
#
# Modes:
#   tmux-hunk-here <pane-id>            Launcher, diff vs origin/main (prefix + +).
#   tmux-hunk-here <pane-id> --branch   Launcher, diff vs origin/<current branch>
#                                       (prefix + Q). If the dir isn't a git repo,
#                                       notify-send with the dir path instead of
#                                       opening a pane.
#   Launcher resolves the repo dir: the working dir of a claude pane in <pane-id>'s
#                              window (the dir claude's statusline shows, which
#                              follows claude as it cd's, not just its launch dir),
#                              falling back to the pane's own cwd when there's no
#                              claude pane. Opens a centered floating pane (~85%)
#                              running review mode there.
#   tmux-hunk-here --review <base>      Runs inside that pane: shows committed,
#                              staged and unstaged changes vs <base> plus untracked
#                              new files, without mutating the index. Holds the pane
#                              open with a message if it can't run.

set -euo pipefail

# ~85% of the window, centered. new-pane takes integer cells only, so 85% is
# expressed as *17/20 to stay integer-only; -X/-Y center it as (dim - size) / 2.
readonly W='#{e|/:#{e|*:#{window_width},17},20}'
readonly H='#{e|/:#{e|*:#{window_height},17},20}'
readonly X='#{e|/:#{e|-:#{window_width},#{e|/:#{e|*:#{window_width},17},20}},2}'
readonly Y='#{e|/:#{e|-:#{window_height},#{e|/:#{e|*:#{window_height},17},20}},2}'

# $1=base ref to diff against (e.g. origin/main or origin/<branch>).
review() {
	local base="$1" root patch f
	root="$(git rev-parse --show-toplevel 2>/dev/null)" || return 1
	cd "$root" || return 1

	# Compose the diff without touching the index: tracked changes vs $base,
	# then each untracked file as an addition. Written to a file (not piped) so
	# hunk's TUI keeps the terminal for keyboard input.
	patch="$(mktemp)"
	trap 'rm -f "$patch"' EXIT
	{
		git diff "$base" || return 1
		git ls-files --others --exclude-standard -z |
			while IFS= read -r -d '' f; do
				git diff --no-index -- /dev/null "$f" || true
			done
	} >"$patch"

	hunk patch "$patch"
}

# First descendant of $1 (inclusive) whose command is claude. Walks a frozen ps
# snapshot with a visited guard so a reparented-process cycle can't loop forever.
claude_pid_under() {
	local root="$1" snapshot p kids nf
	snapshot="$(ps -eo pid=,ppid=,comm=)"
	declare -A seen
	local frontier="$root"
	while [ -n "$frontier" ]; do
		nf=""
		for p in $frontier; do
			[ -n "${seen[$p]:-}" ] && continue
			seen[$p]=1
			[ "$(awk -v x="$p" '$1==x{print $3; exit}' <<<"$snapshot")" = claude ] && {
				printf '%s' "$p"
				return 0
			}
			kids="$(awk -v pp="$p" '$2==pp{print $1}' <<<"$snapshot")"
			nf="$nf $kids"
		done
		frontier="$nf"
	done
	return 1
}

# Current working dir of the claude process under pane pid $1. Claude Code chdir's
# its own process on /cd, so /proc/<pid>/cwd is the live working dir. (The older
# jsonl heuristic picked the wrong session when many claudes share one launch dir.)
claude_current_dir() {
	local claude_pid
	claude_pid="$(claude_pid_under "$1")" || return 0
	readlink "/proc/$claude_pid/cwd" 2>/dev/null || return 0
}

if [[ "${1:-}" == "--review" ]]; then
	if ! review "${2:-origin/main}"; then
		printf '\033[31mhunk could not run here (not a git repo, or %s missing)\033[0m\n' "${2:-origin/main}"
		printf 'press any key to close\n'
		read -r -s -n1
	fi
	exit 0
fi

# Launcher mode. $1 = invoking pane id (#{pane_id} from the bind); $2 = --branch
# to diff vs origin/<current branch> instead of the default origin/main.
pane="${1:?pane id required; call as tmux-hunk-here PANE_ID}"
mode="${2:-}"
self="$(command -v -- "$0" 2>/dev/null || printf '%s' "$0")"

# Repo dir: the claude pane's working dir in this window, else the invoking pane's.
dir=""
claude_pane_pid="$(tmux list-panes -t "$pane" -f '#{==:#{pane_current_command},claude}' -F '#{pane_pid}' | head -n1)"
[ -n "$claude_pane_pid" ] && dir="$(claude_current_dir "$claude_pane_pid")"
[ -n "$dir" ] || dir="$(tmux display-message -p -t "$pane" '#{pane_current_path}')"

# Move the invoking pane's shell to where claude is working. Skip when that pane is
# claude itself, since send-keys would type into claude instead of a shell.
if [ "$(tmux display-message -p -t "$pane" '#{pane_current_command}')" != claude ]; then
	tmux send-keys -t "$pane" " cd \"$dir\"" Enter
fi

# Default base; --branch resolves it to origin/<current branch>, and bails with a
# desktop notification when the resolved dir isn't a git repo.
base="origin/main"
if [[ "$mode" == "--branch" ]]; then
	if ! git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
		notify-send "tmux-hunk-here" "Not in a git repo: $dir"
		exit 0
	fi
	base="origin/$(git -C "$dir" branch --show-current)"
fi

tmux new-pane -t "$pane" -c "$dir" -x "$W" -y "$H" -X "$X" -Y "$Y" "$self --review '$base'"
