#!/usr/bin/env bash
# tmux-claude-title-macos <pane-pid>
# Print a 1-2 word kebab-case summary of the claude session running in the
# given tmux pane, by reading the session JSONL directly. Use this when
# Claude Code's pane_title is the static literal "Claude Code" (current
# behavior on macOS) so summarizing pane_title produces "claude-code"
# instead of a real summary.
#
# Resolution:
#   pane_pid -> claude descendant PID -> PWD env -> ~/.claude/projects/<mangled-pwd>/
#   -> jsonl whose first user-message timestamp is closest to (and not before)
#      the claude process start time -> first user message -> sha1 cache
#   -> claude -p summary

set -u

# --usage (default on) logs per-call token/cost metrics; --no-usage disables.
usage_log=true
pane_pid=""
for arg in "$@"; do
    case "$arg" in
        --usage) usage_log=true ;;
        --no-usage) usage_log=false ;;
        *) [ -z "$pane_pid" ] && pane_pid="$arg" ;;
    esac
done
[ -z "$pane_pid" ] && exit 0

script_name="tmux-claude-title-macos"
# Usage metrics (when usage_log=true and jq is present): every claude -p run
# appends ONE tab-separated row to this append-only log, never overwritten, so
# calls/day and tokens/day can be summed over any range. Columns:
#   date  time  script  input_tokens  cache_read_tokens  output_tokens  cost_usd  summary
# Per-day rollup (calls + tokens + cost):
#   awk -F'\t' '{n[$1]++;i[$1]+=$4;c[$1]+=$5;o[$1]+=$6;u[$1]+=$7}
#     END{for(d in n)printf "%s calls=%d in=%d cache_read=%d out=%d $%.4f\n",d,n[d],i[d],c[d],o[d],u[d]}' \
#     "${XDG_STATE_HOME:-$HOME/.local/state}/tmux-claude-title/usage.log" | sort
usage_log_file="${XDG_STATE_HOME:-$HOME/.local/state}/tmux-claude-title/usage.log"

# Walk descendants of pane_pid via plain ps (pgrep -P is unreliable on macOS).
# Returns one PID per line.
descendants() {
    local root="$1"
    local snapshot
    snapshot=$(ps -axo pid=,ppid= 2>/dev/null) || return
    local stack=("$root")
    while [ ${#stack[@]} -gt 0 ]; do
        local pid="${stack[0]}"
        stack=("${stack[@]:1}")
        echo "$pid"
        local kids
        kids=$(printf '%s\n' "$snapshot" | awk -v p="$pid" '$2==p {print $1}')
        for k in $kids; do stack+=("$k"); done
    done
}

claude_pid=""
# Consider pane_pid itself, not just descendants: claude may be launched
# directly as the pane process (comm=claude / version number) rather than
# under a shell. A shell pane_pid simply won't match the case below.
for pid in $(descendants "$pane_pid"); do
    comm=$(ps -o comm= -p "$pid" 2>/dev/null) || continue
    base="${comm##*/}"
    case "$base" in
        claude|[0-9]*.[0-9]*.[0-9]*) claude_pid="$pid"; break ;;
    esac
done

[ -z "$claude_pid" ] && exit 0

# Pull PWD from the claude process env. ps eww outputs args + env on one line.
env_blob=$(ps eww -p "$claude_pid" -o command= 2>/dev/null) || exit 0
pwd_val=$(printf '%s\n' "$env_blob" | tr ' ' '\n' | awk -F= '$1=="PWD"{print substr($0,5); exit}')
[ -z "$pwd_val" ] && exit 0

mangled=$(printf '%s' "$pwd_val" | tr './' '-')
proj_dir="$HOME/.claude/projects/${mangled}"
[ -d "$proj_dir" ] || exit 0

# Map this pane's claude_pid to its own jsonl. Plain `ls -t` picks the same
# jsonl for every pane sharing a cwd, so all windows end up with the title of
# whichever session was last active. Match by the earliest user-message
# timestamp at-or-after the claude process start time: for fresh sessions
# that's the session's first message, for resumed (`claude -c`) sessions it's
# the first new message after resume. Either way the smallest delta wins.
proc_start_epoch=$(ps -o lstart= -p "$claude_pid" 2>/dev/null \
    | awk '{$1=$1; print}' \
    | xargs -I{} date -j -f "%a %b %e %T %Y" "{}" "+%s" 2>/dev/null)

if [ -z "$proc_start_epoch" ]; then
    jsonl=$(ls -t "$proj_dir"/*.jsonl 2>/dev/null | head -1)
    [ -z "$jsonl" ] || [ ! -f "$jsonl" ] && exit 0
    first_user=$(grep -m1 '"type":"user"' "$jsonl" 2>/dev/null | python3 -c '
import json, sys
try:
    d = json.loads(sys.stdin.read())
    msg = d.get("message", {})
    content = msg.get("content", "")
    if isinstance(content, list):
        for c in content:
            if isinstance(c, dict) and c.get("type") == "text":
                content = c.get("text", "")
                break
        else:
            content = ""
    if isinstance(content, str):
        sys.stdout.write(content)
except Exception:
    pass
' 2>/dev/null)
else
    first_user=$(python3 - "$proj_dir" "$proc_start_epoch" <<'PY' 2>/dev/null
import json, os, sys
from datetime import datetime, timezone
proj_dir, proc_start = sys.argv[1], int(sys.argv[2])
def parse_ts(s):
    try: return datetime.fromisoformat(s.replace("Z", "+00:00")).timestamp()
    except Exception: return None
def text_of(msg):
    c = msg.get("content", "") if isinstance(msg, dict) else ""
    if isinstance(c, list):
        for b in c:
            if isinstance(b, dict) and b.get("type") == "text":
                return b.get("text", "")
        return ""
    return c if isinstance(c, str) else ""
best = (10**9, "")
for name in os.listdir(proj_dir):
    if not name.endswith(".jsonl"): continue
    path = os.path.join(proj_dir, name)
    try:
        with open(path) as f:
            for line in f:
                try: d = json.loads(line)
                except Exception: continue
                if d.get("type") != "user": continue
                ts = parse_ts(d.get("timestamp", ""))
                if ts is None or ts < proc_start - 5: continue
                txt = text_of(d.get("message", {}))
                # Skip tool_result / empty lines: only real prompt text can be a
                # title, and an empty line from a concurrent session in the same
                # cwd must not win the smallest-delta race.
                if not txt.strip(): continue
                delta = abs(int(ts) - proc_start)
                if delta < best[0]:
                    best = (delta, txt)
                break
    except Exception: continue
sys.stdout.write(best[1] or "")
PY
)
fi

[ -z "$first_user" ] && exit 0

# Stopwords dropped from titles so filler like "for"/"the"/"has" never leads or
# trails the summary.
stopwords="a an the and or but for nor of to in on at by with from into onto is are was were be been has have had do does did can could will would shall should may might must not this that these those it its we you they my your our their please just also then as if when while about"

# Drop every stopword token from a kebab string and cap to 3 words. $1=kebab
# string. Keeps titles short and free of filler like "for"/"the"/"has".
tidy_kebab() {
    printf '%s' "$1" | awk -F- -v sw="$stopwords" '
    BEGIN { n=split(sw, a, " "); for (i=1;i<=n;i++) stop[a[i]]=1 }
    {
        c=0; out=""
        for (i=1; i<=NF && c<3; i++) {
            if ($i=="" || ($i in stop)) continue
            out=(out==""?$i:out"-"$i); c++
        }
        print out
    }'
}

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/tmux-claude-title-macos"
mkdir -p "$cache_dir"

key=$(printf '%s' "$first_user" | shasum -a 1 2>/dev/null | cut -c1-16)
[ -z "$key" ] && exit 0
cache_file="$cache_dir/$key"

if [ -s "$cache_file" ]; then
    cat "$cache_file"
    exit 0
fi

# Synchronous fallback while the background summary lands: take the first
# meaningful words of the user's first message, then drop filler and cap to 3.
fallback=$(printf '%s' "$first_user" \
    | head -c 120 \
    | tr 'A-Z' 'a-z' \
    | tr -c 'a-z0-9 ' ' ' \
    | awk '{
        out="";
        for (i=1; i<=NF && i<=8; i++) {
            if (length($i) >= 3) out = (out=="" ? $i : out"-"$i);
        }
        print out;
      }' \
    | sed -E 's/[^a-z0-9-]//g; s/^-+//; s/-+$//')
fallback=$(tidy_kebab "$fallback")
[ -z "$fallback" ] && fallback="claude"
printf '%s' "$fallback"

command -v claude >/dev/null 2>&1 || exit 0

if command -v timeout >/dev/null 2>&1; then
    timeout_cmd=(timeout 30)
elif command -v gtimeout >/dev/null 2>&1; then
    timeout_cmd=(gtimeout 30)
else
    timeout_cmd=()
fi

(
    lockdir="$cache_dir/$key.lockdir"
    mkdir "$lockdir" 2>/dev/null || exit 0
    trap 'rmdir "$lockdir" 2>/dev/null' EXIT

    prompt="Summarize this user request as 2 or 3 lowercase words joined with '-' (e.g. 'reopen-request-bug'). Keep each word separate with a hyphen; never merge words into one run-on token. Prefer 2 words. Skip filler words (the, for, a, to, of, and, is, has). Output ONLY the token, no quotes, no period, no trailing words, no explanation. Request: $first_user"
    # Ask for JSON when logging so token counts return with the summary;
    # otherwise plain text. jq parses the JSON, so fall back without it.
    if [ "$usage_log" = true ] && command -v jq >/dev/null 2>&1; then
        json=$("${timeout_cmd[@]}" claude -p "$prompt" --output-format json 2>/dev/null)
        text=$(printf '%s' "$json" | jq -r '.result // empty' 2>/dev/null)
    else
        json=""
        text=$("${timeout_cmd[@]}" claude -p "$prompt" 2>/dev/null)
    fi
    out=$(printf '%s' "$text" \
        | head -n1 \
        | tr -d '\r\n' \
        | tr 'A-Z' 'a-z' \
        | sed -E 's/[^a-z0-9-]//g; s/^-+//; s/-+$//')
    out=$(tidy_kebab "$out")

    # Append one usage row (see header comment for columns + rollup command).
    if [ -n "$json" ]; then
        mkdir -p "$(dirname "$usage_log_file")"
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$(date +%F)" "$(date +%T)" "$script_name" \
            "$(printf '%s' "$json" | jq -r '.usage.input_tokens // 0')" \
            "$(printf '%s' "$json" | jq -r '.usage.cache_read_input_tokens // 0')" \
            "$(printf '%s' "$json" | jq -r '.usage.output_tokens // 0')" \
            "$(printf '%s' "$json" | jq -r '.total_cost_usd // 0')" \
            "$out" >> "$usage_log_file"
    fi

    # Cache exactly once per key: the LLM summary if it is usable, else the
    # fallback. Writing the cache unconditionally means claude never re-runs for
    # a title that is already set. A hyphenless token longer than 15 chars is a
    # glued run-on, not a real word, so it falls back.
    is_usable=false
    if printf '%s' "$out" | grep -qE '^[a-z0-9]+(-[a-z0-9]+){0,2}$'; then
        case "$out" in
            *-*) is_usable=true ;;
            *) [ "${#out}" -le 15 ] && is_usable=true ;;
        esac
    fi
    if [ "$is_usable" = true ]; then
        printf '%s' "$out" > "$cache_file"
    else
        printf '%s' "$fallback" > "$cache_file"
    fi
    tmux refresh-client -S 2>/dev/null || true
)</dev/null >/dev/null 2>&1 &

disown 2>/dev/null || true
exit 0
