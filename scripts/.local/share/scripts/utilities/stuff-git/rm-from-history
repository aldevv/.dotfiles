#!/bin/bash

# rm-from-history - Remove files from git history with automatic backup
# Usage: rm-from-history <file1> [file2] [file3] ...

set -e

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Error: Not in a git repository${NC}"
    exit 1
fi

# Check if files were provided
if [ $# -eq 0 ]; then
    echo -e "${RED}Error: No files specified${NC}"
    echo "Usage: rm-from-history <file1> [file2] [file3] ..."
    echo "Example: rm-from-history .env .envrc secrets.txt"
    exit 1
fi

# Get the root of the git repository
GIT_ROOT=$(git rev-parse --show-toplevel)

echo -e "${YELLOW}⚠️  WARNING: This will rewrite git history!${NC}"
echo "Files to remove from history: $*"
echo ""
echo "Current branch: $(git branch --show-current)"
echo "Repository: $GIT_ROOT"
echo ""
read -p "Continue? (y/n) " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 0
fi

# Check for uncommitted changes
if ! git diff-index --quiet HEAD -- 2>/dev/null; then
    echo -e "${YELLOW}Uncommitted changes detected. Stashing...${NC}"
    git stash push -m "rm-from-history: Temporary stash ($(date +%Y-%m-%d_%H:%M:%S))"
    STASHED=true
else
    STASHED=false
fi

# Create backup of files that exist
echo ""
echo -e "${GREEN}Creating backups...${NC}"
for file in "$@"; do
    if [ -f "$file" ]; then
        backup_file="${file}.bk-$(date +%Y%m%d_%H%M%S)"
        cp "$file" "$backup_file"
        echo "  ✓ Backed up: $file → $backup_file"
    else
        echo "  ⓘ File doesn't exist locally: $file (will still remove from history)"
    fi
done

# Build filter-branch command
echo ""
echo -e "${GREEN}Removing files from git history...${NC}"
FILTER_CMD="git rm --cached --ignore-unmatch"
for file in "$@"; do
    FILTER_CMD="$FILTER_CMD $file"
done

# Run filter-branch
FILTER_BRANCH_SQUELCH_WARNING=1 git filter-branch \
    --force \
    --index-filter "$FILTER_CMD" \
    --prune-empty \
    --tag-name-filter cat \
    -- --all

# Clean up
echo ""
echo -e "${GREEN}Cleaning up...${NC}"
rm -rf .git/refs/original/
git reflog expire --expire=now --all
git gc --prune=now --aggressive

# Restore stashed changes
if [ "$STASHED" = true ]; then
    echo ""
    echo -e "${GREEN}Restoring stashed changes...${NC}"
    git stash pop
fi

# Verify files are no longer tracked
echo ""
echo -e "${GREEN}✓ Success!${NC}"
echo ""
echo "Files removed from history:"
for file in "$@"; do
    if git ls-files | grep -q "^${file}$"; then
        echo -e "  ${RED}✗ $file (still tracked - something went wrong)${NC}"
    else
        echo -e "  ${GREEN}✓ $file${NC}"
    fi
done

# Check if files should be in .gitignore
echo ""
echo "Checking .gitignore..."
for file in "$@"; do
    if [ -f "$file" ] && ! grep -q "^${file}$" .gitignore 2>/dev/null; then
        echo -e "  ${YELLOW}⚠  $file exists locally but not in .gitignore${NC}"
        read -p "    Add to .gitignore? (y/n) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            echo "$file" >> .gitignore
            echo -e "    ${GREEN}✓ Added to .gitignore${NC}"
        fi
    fi
done

echo ""
echo -e "${YELLOW}⚠️  Next steps:${NC}"
echo "  1. Force push to remote: git push --force-with-lease origin <branch-name>"
echo "  2. Notify team members - they will need to re-clone or reset their branches"
echo ""
