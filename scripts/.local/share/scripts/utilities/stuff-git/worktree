#!/usr/bin/env bash
# worktree: git worktree helper using ~/worktrees/<repo>/<branch> layout.
#
# Safe to source or execute:
#   - executed (`worktree pick`)     prints the selected worktree path
#   - sourced  (`. worktree` / `wt`) cds the calling shell into it
#
# Subcommands:
#   worktree new <branch> [base]   create ~/worktrees/<repo>/<branch> tracking
#                                  <base> (defaults to a new branch off HEAD)
#   worktree -a <branch> [base]    create (or attach) ~/worktrees/<repo>/<branch>
#                                  and cd into it when sourced. If the branch
#                                  doesn't exist it's created off HEAD (or
#                                  <base>); if the worktree already exists we
#                                  just move to it.
#   worktree cd <name>             cd into an existing worktree by name (sourced),
#                                  or print its path (executed). Errors if no
#                                  worktree at ~/worktrees/<repo>/<name>.
#   worktree list                  list every worktree of the current repo
#   worktree rm <branch>           remove the worktree for <branch>
#   worktree clean [name] [--force]
#   worktree -c    [name] [--force]
#                                  with no name: remove every worktree of the
#                                  current repo except the one you're standing
#                                  in. With a name: remove just that one.
#                                  --force drops uncommitted changes too.
#   worktree pick                  fzf-pick a worktree of the current repo
#                                  and print its path. Inside the picker,
#                                  ctrl-c creates the typed worktree (and cds
#                                  into it when sourced), ctrl-x removes the
#                                  highlighted worktree and reloads the list.
#                                  When sourced with no subcommand, the `wt`
#                                  alias turns that path into a `cd`.
#   worktree pick-all              fzf-pick a worktree across EVERY managed
#                                  repo under WT_HOME and print its path.
#                                  Used automatically when bare `worktree` /
#                                  `wt` runs outside any git repo. ctrl-x
#                                  still removes the highlighted worktree;
#                                  ctrl-c is fzf's default abort because
#                                  creating a worktree needs repo context.
#   worktree root                  print the worktrees-root for the current
#                                  repo (~/worktrees/<reponame>)
#   worktree skill [--base <path>] install a Claude skill at
#                                  ~/.claude/skills/worktrees/SKILL.md telling
#                                  Claude where worktrees live. --base sets
#                                  the documented base; default is
#                                  ${WT_HOME:-$HOME/worktrees}.
#   worktree help                  show this help
#
# With no subcommand the script behaves like `worktree pick` inside a git
# repo, and like `worktree pick-all` outside one.
# Override the parent dir with WT_HOME=... in the environment.

# Detect whether we were sourced or executed. The sourced path has to cd in
# the caller's shell; the executed path just prints.
__wt_sourced() {
  if [ -n "${ZSH_VERSION:-}" ]; then
    case "${ZSH_EVAL_CONTEXT:-}" in *:file*) return 0 ;; esac
    return 1
  fi
  if [ -n "${BASH_VERSION:-}" ]; then
    [ "${BASH_SOURCE[0]}" != "${0}" ]
    return
  fi
  return 1
}

# Core logic runs in a subshell (function body is `(...)` not `{...}`) so
# `set -euo pipefail` and any helper functions defined below don't leak into
# the caller's interactive shell when sourced.
__wt_run() (
  set -eu -o pipefail

  WORKTREE_HOME="${WT_HOME:-$HOME/worktrees}"

  die() {
    printf 'wt: %s\n' "$*" >&2
    return 1
  }

  require_git_repo() {
    git rev-parse --show-toplevel >/dev/null 2>&1 \
      || die "not in a git repository"
  }

  # Group worktrees under the main checkout's directory name, so `wt` from
  # inside a worktree still resolves to the same parent.
  canonical_repo_name() {
    local main_root
    main_root="$(git worktree list --porcelain \
      | awk '/^worktree / { print $2; exit }')"
    basename "$main_root"
  }

  worktrees_root() {
    printf '%s/%s' "$WORKTREE_HOME" "$(canonical_repo_name)"
  }

  main_worktree_path() {
    git worktree list --porcelain | awk '/^worktree / { print $2; exit }'
  }

  # Worktrees only inherit `.git`, not working-tree files. Symlink the main
  # checkout's per-checkout config (direnv, Claude project memory, agent
  # configs) so they follow you into a new worktree. Skips a name if the
  # source is missing, if the target already exists (including as a checked-in
  # file from the branch), or if target == main.
  link_main_files() {
    local target="$1"
    local main_root="$2"
    [ "$target" != "$main_root" ] || return 0
    local name
    for name in .envrc CLAUDE.md CLAUDE.local.md .claude; do
      [ -e "$main_root/$name" ] || [ -L "$main_root/$name" ] || continue
      [ -e "$target/$name" ] && continue
      [ -L "$target/$name" ] && continue
      ln -s "$main_root/$name" "$target/$name"
    done
  }

  print_help() {
    cat <<'EOF'
worktree: git worktree helper

Usage:
  worktree                       same as `worktree pick`
  worktree new <branch> [base]   create ~/worktrees/<repo>/<branch>
  worktree -a  <branch> [base]   create or attach, then cd when sourced
  worktree cd  <name>            cd into an existing worktree (sourced)
  worktree list                  list worktrees of the current repo
  worktree rm <branch>           remove one worktree
  worktree clean [name] [--force]
  worktree -c    [name] [--force]
                                 no name: remove every non-main, non-current
                                 worktree. with name: remove just that one.
  worktree pick                  print the fzf-selected worktree path
                                 (ctrl-c creates typed name, ctrl-x removes)
  worktree pick-all              fzf-pick across EVERY managed repo under
                                 WT_HOME (ctrl-x removes). used automatically
                                 when bare `worktree` runs outside any repo
  worktree root                  print the worktrees-root for the current repo
  worktree skill [--base <path>] install a Claude skill describing the layout
  worktree help                  show this help

Layout: ~/worktrees/<reponame>/<branchname>.
Override the parent dir with WT_HOME=... in the environment.

The `wt` alias sources this script so bare `wt` cds you into the chosen
worktree; running `worktree` directly keeps the print-only behavior for
`$(worktree)` callers.
EOF
  }

  cmd_root() {
    require_git_repo
    printf '%s\n' "$(worktrees_root)"
  }

  cmd_list() {
    require_git_repo
    git worktree list
  }

  # TSV rows for every worktree under WORKTREE_HOME, across every managed
  # repo. Format: <repo>\t<branch>\t<worktree-path>. The main checkout is
  # excluded so the picker only offers actual worktrees to cd into.
  #
  # `find` instead of globs so we don't trip zsh's NOMATCH when a managed
  # <repo>/ dir is empty (this script is sourced by the `wt` zsh function).
  # Porcelain is captured into a variable so awk can read it without an
  # early `exit`, which would SIGPIPE the producer under pipefail.
  cmd_picker_list_all() {
    [ -d "$WORKTREE_HOME" ] || die "no worktrees root at $WORKTREE_HOME"

    local repo_dir first_wt porcelain main_path main_name
    while IFS= read -r repo_dir; do
      first_wt="$(find "$repo_dir" -mindepth 1 -maxdepth 1 -type d \
        -print -quit 2>/dev/null)"
      [ -n "$first_wt" ] || continue

      porcelain="$(git -C "$first_wt" worktree list --porcelain 2>/dev/null || true)"
      [ -n "$porcelain" ] || continue

      main_path="$(printf '%s\n' "$porcelain" \
        | awk '$1 == "worktree" && p == "" { p = $2 } END { print p }')"
      [ -n "$main_path" ] || continue
      main_name="$(basename "$main_path")"

      printf '%s\n' "$porcelain" \
        | awk -v main="$main_path" -v repo="$main_name" '
            $1 == "worktree" { wt = $2; branch = ""; next }
            $1 == "branch"   { sub(/^refs\/heads\//, "", $2); branch = $2 }
            $1 == "detached" { branch = "(detached)" }
            /^$/ && wt {
              if (wt != main) printf "%s\t%s\t%s\n", repo, branch ? branch : "(no branch)", wt
              wt = ""; branch = ""
            }
            END {
              if (wt && wt != main) printf "%s\t%s\t%s\n", repo, branch ? branch : "(no branch)", wt
            }
          '
    done < <(find "$WORKTREE_HOME" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
  }

  # fzf picker for bare `worktree` / `wt` run outside any git repo. Lists
  # every worktree across every managed repo, lets the user cd into one
  # (Enter) or remove one (ctrl-x + reload). ctrl-c is left as fzf's
  # default abort: creating a new worktree from outside a repo has no
  # repo context to anchor against.
  cmd_pick_all() {
    [ -d "$WORKTREE_HOME" ] || die "no worktrees root at $WORKTREE_HOME"
    command -v fzf >/dev/null 2>&1 || die "fzf not installed"

    local rows selection
    rows="$(cmd_picker_list_all)"
    [ -n "$rows" ] || die "no worktrees found under $WORKTREE_HOME"

    selection="$(
      printf '%s\n' "$rows" \
        | fzf --delimiter=$'\t' --with-nth=1,2,3 \
              --height=80% --reverse \
              --prompt='worktree> ' \
              --header='enter: cd   ctrl-x: remove worktree' \
              --bind="ctrl-x:execute-silent(git worktree remove {3} 2>/dev/null || git worktree remove --force {3} 2>/dev/null)+reload(worktree _picker-list-all)" \
              --preview='git -C {3} log --color=always --format="%C(auto)%h%d%C(reset)%n  %s" -25' \
              --preview-window='right:60%:wrap'
    )" || true

    [ -n "$selection" ] || return 1
    printf '%s\n' "${selection##*$'\t'}"
  }

  cmd_picker_list() {
    require_git_repo
    git worktree list --porcelain \
      | awk '
          $1 == "worktree" { wt = $2; branch = ""; next }
          $1 == "branch"   { sub(/^refs\/heads\//, "", $2); branch = $2 }
          $1 == "detached" { branch = "(detached)" }
          /^$/ && wt {
            printf "%s\t%s\n", branch ? branch : "(no branch)", wt
            wt = ""; branch = ""
          }
          END {
            if (wt) printf "%s\t%s\n", branch ? branch : "(no branch)", wt
          }
        '
  }

  cmd_pick() {
    require_git_repo
    mkdir -p "$(worktrees_root)"
    command -v fzf >/dev/null 2>&1 || die "fzf not installed"

    # ctrl-x removes the highlighted worktree (including the one the user
    # is currently standing in) and reloads the list. ctrl-c creates a
    # worktree named after whatever the user typed in the prompt
    # (delegating to cmd_add) and prints its path so the sourced wrapper
    # cds into it. The reload calls back into this same script (`worktree
    # _picker-list`) so the awk pipeline stays in one place.
    #
    # main_root / current_root are captured BEFORE fzf launches so:
    #   * The reload runs after `cd $main_root`, immunizing it against a
    #     stale cwd when the user just ctrl-x'd the worktree they were in.
    #   * After fzf exits we can detect "current worktree was deleted" and
    #     send the user to the main checkout instead of stranding them in
    #     a deleted directory.
    #
    # Note: rebinding ctrl-c overrides fzf's default abort-on-ctrl-c.
    # Esc still aborts the picker.
    #
    # --print-query + --expect=ctrl-c make fzf emit:
    #   line 1: the typed query
    #   line 2: the key that exited (empty = Enter, "ctrl-c" = our binding)
    #   line 3: the highlighted row (or empty if none)
    local main_root current_root
    main_root="$(main_worktree_path)"
    current_root="$(git rev-parse --show-toplevel)"

    local output
    output="$(
      cmd_picker_list \
        | fzf --delimiter=$'\t' --with-nth=1,2 \
              --height=80% --reverse \
              --prompt='worktree> ' \
              --header='enter: cd   ctrl-c: create+cd   ctrl-x: remove worktree' \
              --expect=ctrl-c \
              --print-query \
              --bind="ctrl-x:execute-silent(git worktree remove {2} 2>/dev/null || git worktree remove --force {2} 2>/dev/null)+reload(cd ${main_root} && worktree _picker-list)" \
              --preview='git -C {2} log --color=always --format="%C(auto)%h%d%C(reset)%n  %s" -25' \
              --preview-window='right:60%:wrap'
    )" || true

    # Use `read` in a group rather than `mapfile`: the script may be sourced
    # into a zsh shell (via the `wt` function), and `mapfile` is bash-only.
    # `|| true` swallows the read EOF when fewer than three lines came back
    # (e.g. ctrl-c with no matching row underneath the prompt).
    local query='' key='' selection=''
    { IFS= read -r query; IFS= read -r key; IFS= read -r selection; } <<< "$output" || true

    if [ "$key" = "ctrl-c" ]; then
      [ -n "$query" ] || die "ctrl-c needs a typed worktree name"
      cmd_add "$query"
      return
    fi

    if [ -n "$selection" ]; then
      printf '%s\n' "${selection##*$'\t'}"
      return
    fi

    # No explicit selection. If the user ctrl-x'd their current worktree
    # mid-session, send the parent shell to the main checkout so it isn't
    # stranded in a deleted directory.
    if [ ! -d "$current_root" ]; then
      printf '%s\n' "$main_root"
      return
    fi

    return 1
  }

  cmd_add() {
    require_git_repo
    local branch="${1:-}"
    local base="${2:-}"
    [ -n "$branch" ] || die "usage: worktree -a <branch> [base]"

    local target
    target="$(worktrees_root)/$branch"
    mkdir -p "$(dirname "$target")"

    # Redirect `git worktree add` chatter to stderr so stdout is only the
    # target path (captured by the sourced wrapper for the cd).
    if [ -d "$target" ]; then
      :
    elif git show-ref --verify --quiet "refs/heads/$branch"; then
      git worktree add "$target" "$branch" >&2
    elif [ -n "$base" ]; then
      git worktree add -b "$branch" "$target" "$base" >&2
    else
      git worktree add -b "$branch" "$target" >&2
    fi

    link_main_files "$target" "$(main_worktree_path)" >&2 || true

    printf '%s\n' "$target"
  }

  cmd_new() {
    require_git_repo
    local branch="${1:-}"
    local base="${2:-}"
    [ -n "$branch" ] || die "usage: worktree new <branch> [base]"

    local target
    target="$(worktrees_root)/$branch"

    mkdir -p "$(dirname "$target")"

    if git show-ref --verify --quiet "refs/heads/$branch"; then
      git worktree add "$target" "$branch"
    elif [ -n "$base" ]; then
      git worktree add -b "$branch" "$target" "$base"
    else
      git worktree add -b "$branch" "$target"
    fi

    link_main_files "$target" "$(main_worktree_path)"
  }

  cmd_cd() {
    require_git_repo
    local name="${1:-}"
    [ -n "$name" ] || die "usage: worktree cd <name>"

    local target
    target="$(worktrees_root)/$name"
    [ -d "$target" ] || die "no worktree at $target"
    printf '%s\n' "$target"
  }

  cmd_rm() {
    require_git_repo
    local branch="${1:-}"
    [ -n "$branch" ] || die "usage: worktree rm <branch>"

    local target
    target="$(worktrees_root)/$branch"

    [ -d "$target" ] || die "no worktree at $target"
    git worktree remove "$target"
    rmdir "$(dirname "$target")" 2>/dev/null || true
  }

  cmd_clean() {
    require_git_repo
    local force=0 name=""

    # Accept any order of `[name]` and `--force/-f`. Multiple bare args would
    # be ambiguous; first non-flag wins, the rest are an error.
    for arg in "$@"; do
      case "$arg" in
        --force|-f) force=1 ;;
        -*) die "unknown flag: $arg" ;;
        *)
          [ -z "$name" ] || die "unexpected extra argument: $arg"
          name="$arg"
          ;;
      esac
    done

    # With a name, act as a targeted remove (delete just that worktree).
    if [ -n "$name" ]; then
      local target
      target="$(worktrees_root)/$name"
      [ -d "$target" ] || die "no worktree at $target"
      if [ "$force" = "1" ]; then
        git worktree remove --force "$target"
      else
        git worktree remove "$target"
      fi
      rmdir "$(dirname "$target")" 2>/dev/null || true
      return
    fi

    local current_root main_root removed=0 line wt
    current_root="$(git rev-parse --show-toplevel)"
    main_root="$(main_worktree_path)"

    while IFS= read -r line; do
      case "$line" in
        "worktree "*) wt="${line#worktree }" ;;
        *) continue ;;
      esac
      [ "$wt" = "$main_root" ] && continue
      [ "$wt" = "$current_root" ] && continue

      if [ "$force" = "1" ]; then
        git worktree remove --force "$wt" && removed=$((removed + 1))
      else
        git worktree remove "$wt" && removed=$((removed + 1))
      fi
    done < <(git worktree list --porcelain)

    rmdir "$(worktrees_root)" 2>/dev/null || true
    printf 'wt: removed %d worktree(s)\n' "$removed"
  }

  cmd_skill() {
    local base="${WT_HOME:-$HOME/worktrees}"
    while [ $# -gt 0 ]; do
      case "$1" in
        --base) shift; base="${1:-}"; [ -n "$base" ] || die "--base requires a path" ;;
        --base=*) base="${1#--base=}" ;;
        -*) die "unknown flag: $1" ;;
        *) die "unexpected argument: $1" ;;
      esac
      shift
    done

    local skill_dir="${HOME}/.claude/skills/worktrees"
    local skill_file="${skill_dir}/SKILL.md"
    mkdir -p "$skill_dir"

    cat >"$skill_file" <<EOF
---
name: worktrees
description: Git worktree layout on this machine. Read whenever the user references a worktree by name, mentions \`wt\` or \`worktree\`, asks to create/list/cd/remove a worktree, or refers to a path under \`${base}\`. Tells you the base path and naming convention so paths resolve without guessing.
---

# Worktree layout

Git worktrees on this machine live at:

    ${base}/<repo>/<branch>

Where:
- \`<repo>\` is the basename of the main checkout's top-level directory.
- \`<branch>\` is the worktree's branch name.

The base is configurable via \`WT_HOME\` in the environment; when this skill was installed it resolved to \`${base}\`.

## The \`worktree\` helper

A \`worktree\` script (on \`PATH\`, also exposed as the \`wt\` shell function) manages this layout. Subcommands:

| Subcommand                  | Effect                                           |
|-----------------------------|--------------------------------------------------|
| \`worktree\` / \`worktree pick\` | fzf-pick a worktree and \`cd\` (sourced) / print |
| \`worktree new <branch>\`     | create \`${base}/<repo>/<branch>\` off HEAD       |
| \`worktree -a <branch>\`      | create-or-attach, then \`cd\` when sourced         |
| \`worktree cd <name>\`        | \`cd\` into an existing worktree by name           |
| \`worktree list\`             | list worktrees of the current repo               |
| \`worktree rm <branch>\`      | remove one worktree                              |
| \`worktree clean\`            | remove every non-main, non-current worktree      |
| \`worktree root\`             | print \`${base}/<repo>\` for the current repo     |
| \`worktree help\`             | show full usage                                  |

## Symlinks created on \`new\` / \`-a\`

When a worktree is created via \`worktree new\` or \`worktree -a\`, the helper symlinks the following from the main checkout into the new worktree, so per-checkout config follows you in:

- \`.envrc\` (direnv)
- \`CLAUDE.md\`
- \`CLAUDE.local.md\`
- \`.claude/\`

A name is skipped when the source doesn't exist in the main checkout or when the new worktree already has its own (e.g. checked into the branch). This means inside a worktree those paths typically resolve to the main checkout; treat edits to them as edits to the main checkout's copy.

## Resolving names

When the user references "the \`X\` worktree" from inside a repo, resolve to \`${base}/<current-repo>/X\`. To get \`<current-repo>\`:

\`\`\`bash
git worktree list --porcelain | awk '/^worktree / { print \$2; exit }' | xargs basename
\`\`\`

Reinstall this skill (e.g. after changing the base) by running \`worktree skill --base <new>\`.
EOF

    printf 'wt: wrote %s (base=%s)\n' "$skill_file" "$base"
  }

  local sub="${1:-pick}"
  [ "$#" -gt 0 ] && shift

  # Bare `worktree` outside any repo runs the global picker across every
  # managed repo instead of dying inside cmd_pick's require_git_repo.
  # Explicit subcommands still error out when they need a repo.
  if [ "$sub" = "pick" ] \
     && ! git rev-parse --show-toplevel >/dev/null 2>&1; then
    sub="pick-all"
  fi

  case "$sub" in
    new) cmd_new "$@" ;;
    -a|add) cmd_add "$@" ;;
    cd) cmd_cd "$@" ;;
    list|ls) cmd_list "$@" ;;
    rm|remove) cmd_rm "$@" ;;
    clean|-c) cmd_clean "$@" ;;
    pick) cmd_pick "$@" ;;
    pick-all|all) cmd_pick_all "$@" ;;
    _picker-list) cmd_picker_list ;;
    _picker-list-all) cmd_picker_list_all ;;
    root) cmd_root "$@" ;;
    skill) cmd_skill "$@" ;;
    -h|--help|help) print_help ;;
    *) die "unknown subcommand: $sub (try 'worktree help')" ;;
  esac
)

if __wt_sourced; then
  # Bare `wt` → pick + cd. Inside a repo: picks among the repo's worktrees.
  # Outside any repo: picks across every managed repo (dispatch routes
  # `pick` → `pick-all` in that case). `wt -a <branch>` → create/attach +
  # cd. Other subcommands just pass through (stdout flows to the terminal).
  if [ "$#" -eq 0 ]; then
    __wt_target="$(__wt_run pick)"
    [ -n "${__wt_target:-}" ] && cd "$__wt_target"
    unset __wt_target
  elif [ "${1:-}" = "-a" ] || [ "${1:-}" = "add" ] || [ "${1:-}" = "cd" ]; then
    __wt_target="$(__wt_run "$@")"
    [ -n "${__wt_target:-}" ] && cd "$__wt_target"
    unset __wt_target
  else
    __wt_run "$@"
  fi
  unset -f __wt_sourced __wt_run
else
  __wt_run "$@"
fi
