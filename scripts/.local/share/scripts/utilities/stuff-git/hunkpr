#!/bin/bash
# Open `hunk diff` for a GitHub PR.
# Usage: hunkpr [<pr-url-or-number>]
#
#   no arg     → resolve via `gh pr view` (current branch's PR; cwd must be the repo)
#   <number>   → uses gh's repo detection from cwd
#   <url>      → finds a local clone of the URL's repo in ~/repos, ~/work,
#                $PROJECTS, $CODE; falls back to cloning into ~/.cache/hunk/pr/
#
# GitHub publishes pull/<num>/head for every PR (incl. forks), so a clone
# of the *upstream* repo is enough — no need to add the fork as a remote.
#
# Exit codes: 0 ok, 1 usage, 2 resolve, 3 fetch, 4 clone, 127 missing dep.
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: hunkpr [<pr-url-or-number>]

Open `hunk diff` for a GitHub PR's branch (base...head).

Examples:
  hunkpr                                          # current branch's PR
  hunkpr 123                                      # PR in cwd's repo
  hunkpr https://github.com/owner/repo/pull/123   # auto-finds local clone

Searches for the upstream clone in $PWD, ~/repos, ~/work, $PROJECTS, $CODE.
Auto-clones to ~/.cache/hunk/pr/<owner>/<repo> if no local clone is found.
Requires: gh, hunk, jq.
EOF
}

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
esac
[[ $# -le 1 ]] || { usage >&2; exit 1; }

for cmd in gh hunk jq; do
  command -v "$cmd" >/dev/null \
    || { echo "hunkpr: \`$cmd\` not found on PATH" >&2; exit 127; }
done

arg="${1:-}"

# Show fetch/clone progress to a TTY; stay quiet under pipes (cron, scripts).
quiet=()
[[ -t 2 ]] || quiet=(--quiet)

# --- Resolve upstream + (when possible) PR number without an API call ---
# When the input is a URL, both fall out of regex matches — saves a round
# trip to GitHub. Otherwise we fall back to parsing the cwd's origin remote
# (also free, vs. `gh repo view` which is another API call).

upstream=""
num_from_url=""
if [[ "$arg" =~ ^https?://[^/]+/([^/]+/[^/]+)/pull/([0-9]+) ]]; then
  upstream="${BASH_REMATCH[1]%.git}"
  num_from_url="${BASH_REMATCH[2]}"
elif [[ -z "$arg" || "$arg" =~ ^[0-9]+$ ]]; then
  origin_url=$(git remote get-url origin 2>/dev/null) \
    || { echo "hunkpr: not in a git repo and no URL given" >&2; exit 2; }
  # HTTPS first — the SSH pattern `^[^:]+:` would otherwise match `https:`.
  # Both branches are host-agnostic so GitHub Enterprise origins resolve.
  if   [[ "$origin_url" =~ ^https?://[^/]+/([^/]+/[^/]+)$ ]]; then upstream="${BASH_REMATCH[1]%.git}"
  elif [[ "$origin_url" =~ ^[^/:@]+@[^:]+:([^/]+/[^/]+)$ ]];   then upstream="${BASH_REMATCH[1]%.git}"
  fi
fi
[[ -n "$upstream" ]] \
  || { echo "hunkpr: couldn't determine upstream repo from \`$arg\` (not in a git repo, origin isn't a GitHub-style remote, or arg isn't a PR URL/number)" >&2; exit 2; }

# --- Find or clone the local working dir for that upstream ---

remote_matches() {
  local url="$1" target="$2"
  [[ "$url" == *"/${target}.git" || "$url" == *"/${target}" \
    || "$url" == *":${target}.git" || "$url" == *":${target}" ]]
}

find_clone() {
  local target="$1" basename="$2" url root dir
  if root=$(git -C . rev-parse --show-toplevel 2>/dev/null); then
    url=$(git -C "$root" remote get-url origin 2>/dev/null || true)
    remote_matches "$url" "$target" && { echo "$root"; return 0; }
  fi
  for dir in "$HOME/repos" "$HOME/work" "${PROJECTS:-}" "${CODE:-}"; do
    [[ -d "$dir/$basename/.git" ]] || continue
    url=$(git -C "$dir/$basename" remote get-url origin 2>/dev/null || true)
    remote_matches "$url" "$target" && { echo "$dir/$basename"; return 0; }
  done
  return 1
}

# Cache key includes the host so the same `owner/repo` on github.com vs an
# enterprise host doesn't collide. Shared with `h` and `hunkmr` via
# ~/.cache/hunk/repos.tsv. Schema (4 cols):
#   <host/owner/repo>\t<forge>\t<local-path>\t<base-branch>
cache_root="${XDG_CACHE_HOME:-$HOME/.cache}/hunk"
cache_file="$cache_root/repos.tsv"
cache_key=""
cache_host=""
if [[ "$arg" =~ ^https?://([^/]+)/ ]]; then
  cache_host="${BASH_REMATCH[1]}"
elif [[ -n "${origin_url:-}" ]]; then
  if   [[ "$origin_url" =~ ^https?://([^/]+)/ ]]; then cache_host="${BASH_REMATCH[1]}"
  elif [[ "$origin_url" =~ ^[^/:@]+@([^:]+):  ]]; then cache_host="${BASH_REMATCH[1]}"
  fi
fi
[[ -n "$cache_host" ]] && cache_key="$cache_host/$upstream"

# Read existing row once: pulls forge, path, base in a single awk pass.
cached_forge=""
cached_path=""
cached_base=""
if [[ -n "$cache_key" && -f "$cache_file" ]]; then
  IFS=$'\t' read -r _ cached_forge cached_path cached_base < <(
    awk -F'\t' -v k="$cache_key" '$1==k {print; exit}' "$cache_file"
  ) || true
fi

# Resolve repo_dir: cache hit if path still valid, otherwise find_clone or clone.
repo_dir=""
[[ -n "$cached_path" && -d "$cached_path/.git" ]] && repo_dir="$cached_path"
if [[ -z "$repo_dir" ]]; then
  repo_dir="$(find_clone "$upstream" "${upstream##*/}")" || {
    clone_dir="$cache_root/pr/$upstream"
    if [[ ! -d "$clone_dir/.git" ]]; then
      echo "hunkpr: no local clone for $upstream — cloning to $clone_dir" >&2
      mkdir -p "$(dirname "$clone_dir")"
      gh repo clone "$upstream" "$clone_dir" -- "${quiet[@]}" --filter=blob:none \
        || { echo "hunkpr: failed to clone $upstream" >&2; exit 4; }
    fi
    repo_dir="$clone_dir"
  }
fi

# Detect default base branch (`main` vs `master`, etc.) — try origin/HEAD,
# then probe well-known names, then settle on `main`. Cache means we only
# pay this once per repo.
base_branch="$cached_base"
if [[ -z "$base_branch" ]]; then
  base_branch=$(git -C "$repo_dir" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null || true)
  base_branch="${base_branch#origin/}"
  if [[ -z "$base_branch" ]]; then
    for cand in main master; do
      git -C "$repo_dir" rev-parse --verify --quiet "origin/$cand" >/dev/null 2>&1 \
        && { base_branch="$cand"; break; }
    done
  fi
  base_branch="${base_branch:-main}"
fi

# Persist if anything changed. Preserves whichever of (forge, path, base)
# was filled in by `h` / a prior run.
if [[ -n "$cache_key" ]]; then
  forge="${cached_forge:-github}"
  if [[ "$cached_forge" != "$forge" || "$cached_path" != "$repo_dir" || "$cached_base" != "$base_branch" ]]; then
    mkdir -p "$cache_root"
    [[ -f "$cache_file" ]] || : > "$cache_file"
    tmp="${cache_file}.tmp.$$"
    awk -F'\t' -v k="$cache_key" '$1!=k' "$cache_file" > "$tmp"
    printf '%s\t%s\t%s\t%s\n' "$cache_key" "$forge" "$repo_dir" "$base_branch" >> "$tmp"
    mv "$tmp" "$cache_file"
  fi
fi

# --- Speculative head fetch in parallel with `gh pr view` ---
# When the URL gave us the PR number, kick off the fetch now. The gh call
# (~300ms) and the fetch (~300-800ms) overlap; on cold cache this nearly
# halves wall time. The bg fetch's only job is to bring the commit object
# into the repo — the foreground block below names the ref.
bg_fetch_pid=""
if [[ -n "$num_from_url" ]]; then
  git -C "$repo_dir" fetch --quiet origin \
    "pull/${num_from_url}/head:refs/remotes/origin/pr/${num_from_url}" \
    >/dev/null 2>&1 &
  bg_fetch_pid=$!
fi

# --- Resolve PR metadata: number, base ref, head SHA. ---
# Capture stderr so failures (auth expired, rate-limit, network) surface
# instead of being hidden behind a generic message.
# `gh pr view --repo X` requires a positional arg, so for the no-arg case
# we drop --repo and let gh auto-detect the current branch from cwd.
gh_args=(pr view --json number,baseRefName,headRefOid)
[[ -n "$arg" ]] && gh_args+=(--repo "$upstream" "$arg")
if ! pr_json=$(gh "${gh_args[@]}" 2>&1); then
  [[ -n "$bg_fetch_pid" ]] && { wait "$bg_fetch_pid" 2>/dev/null || true; }
  # No-arg + "no PR for this branch" → fall back to plain `hunk diff main`.
  # Covers the "branch pushed, PR not yet open" flow without forcing the
  # user to run a different command. Other gh failures (auth, network) still
  # error out so they're not silently masked.
  if [[ -z "$arg" ]] && grep -qiE 'no (open )?(pull request|pull requests)' <<<"$pr_json"; then
    cd "$repo_dir"
    exec hunk diff "$base_branch"
  fi
  printf 'hunkpr: failed to resolve PR `%s`\n%s\n' "${arg:-(current branch)}" "$pr_json" >&2
  [[ -z "$arg" ]] && echo 'hint: pass a PR number/URL, or push the branch and open a PR first' >&2
  exit 2
fi

# Single jq call — three separate `jq -r` invocations meant three forks.
{ IFS=$'\t' read -r num base head_sha || true; } < <(
  jq -r '[.number, .baseRefName, .headRefOid] | @tsv' <<<"$pr_json"
)
[[ "$head_sha" =~ ^[0-9a-f]{40}$ ]] \
  || { echo "hunkpr: gh returned invalid head SHA \`$head_sha\`" >&2; exit 2; }

if [[ -n "$bg_fetch_pid" ]]; then
  wait "$bg_fetch_pid" 2>/dev/null || true
fi

# Fast path: head commit already local (warm clone, or our bg fetch landed
# it) → just point the pr/<num> ref at it, no foreground fetch.
if git -C "$repo_dir" rev-parse --verify "${head_sha}^{commit}" >/dev/null 2>&1; then
  git -C "$repo_dir" update-ref "refs/remotes/origin/pr/${num}" "$head_sha"
else
  git -C "$repo_dir" fetch "${quiet[@]}" origin \
    "pull/${num}/head:refs/remotes/origin/pr/${num}" \
    || { echo "hunkpr: failed to fetch pull/${num}/head" >&2; exit 3; }
fi

# Only fetch the base ref if we don't have it — `A...B` for diff resolves
# to the merge-base, which doesn't move unless the base is force-pushed,
# so a stale `origin/<base>` is fine for diff context.
if ! git -C "$repo_dir" rev-parse --verify "origin/$base" >/dev/null 2>&1; then
  git -C "$repo_dir" fetch "${quiet[@]}" origin "$base" \
    || { echo "hunkpr: failed to fetch base \`$base\`" >&2; exit 3; }
fi

cd "$repo_dir"
exec hunk diff "origin/${base}...origin/pr/${num}"
