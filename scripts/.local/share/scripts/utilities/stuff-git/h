#!/bin/bash
# h: thin wrapper around `hunk` plus one shortcut for URLs.
#
# Usage:
#   h                                                  exec hunk (its own no-arg behavior)
#   h <hunk-subcommand> [args...]                      exec hunk "$@"
#   h https://github.com/owner/repo                    clone via _clone, hunk diff origin/<main>
#   h https://github.com/owner/repo/pull/123           clone, fetch pull/123/head, hunk diff origin/<base>...origin/pr/123
#   h https://gitlab.com/g/p                           clone via _clone, hunk diff origin/<main>
#   h https://gitlab.com/g/p/-/merge_requests/45       clone, fetch merge-requests/45/head, hunk diff origin/<target>...origin/mr/45
#
# Clones go to $REPOS/<host>/<owner>/<repo> via the _clone helper (which prompts
# before overwriting an existing checkout). PR/MR head is fetched as
# origin/(pr|mr)/<N>; no working-tree checkout, fork heads work without adding
# a remote.
#
# Exit codes: 0 ok, 1 usage, 2 resolve, 3 fetch, 4 clone, 127 missing dep.
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: h [<github-or-gitlab-url> | <hunk-subcommand> [args...]]

  no arg                                    exec hunk
  github/gitlab repo URL                    clone, hunk diff origin/<main>
  github PR URL / gitlab MR URL             clone, fetch head, diff base..head
  anything else                             exec hunk with all args

Clones go to $REPOS/<host>/<owner>/<repo> via the _clone helper.
Requires: hunk, jq; gh for GitHub PR URLs; glab for GitLab MR URLs.
EOF
}

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
esac

arg="${1:-}"

# Pass-through path: no arg, or arg doesn't look like an http(s) URL.
if [[ ! "$arg" =~ ^https?:// ]]; then
  if [[ $# -eq 0 ]]; then
    exec hunk
  fi
  exec hunk "$@"
fi

[[ $# -le 1 ]] || { usage >&2; exit 1; }

command -v hunk >/dev/null || { echo "h: \`hunk\` not on PATH" >&2; exit 127; }
[[ -n "${REPOS:-}" ]] || { echo "h: \$REPOS is not set (needed by _clone)" >&2; exit 2; }

url_clean="${arg%%\?*}"
url_clean="${url_clean%%#*}"
url_clean="${url_clean%/}"

rest="${url_clean#http://}"; rest="${rest#https://}"
host="${rest%%/*}"
path_part="${rest#*/}"

case "$host" in
  *github*) forge=github ;;
  *gitlab*) forge=gitlab ;;
  *) echo "h: unsupported host \`$host\` (expected github or gitlab)" >&2; exit 2 ;;
esac

pr_num=""
repo_path=""
case "$forge" in
  github)
    if   [[ "$path_part" =~ ^([^/]+/[^/]+)/pull/([0-9]+) ]]; then
      repo_path="${BASH_REMATCH[1]}"; pr_num="${BASH_REMATCH[2]}"
    elif [[ "$path_part" =~ ^([^/]+/[^/]+) ]]; then
      repo_path="${BASH_REMATCH[1]}"
    else
      echo "h: can't parse GitHub URL \`$arg\`" >&2; exit 2
    fi
    ;;
  gitlab)
    # GitLab uses /-/ as the path-vs-resource separator. Anything before it is
    # the project path (groups can nest, so it isn't just owner/repo).
    if [[ "$path_part" =~ ^(.+)/-/merge_requests/([0-9]+) ]]; then
      repo_path="${BASH_REMATCH[1]}"; pr_num="${BASH_REMATCH[2]}"
    else
      repo_path="${path_part%%/-/*}"
    fi
    ;;
esac
repo_path="${repo_path%.git}"
[[ -n "$repo_path" ]] || { echo "h: empty repo path in URL \`$arg\`" >&2; exit 2; }

repo_url="https://$host/$repo_path"
canonical_dir="$REPOS/$host/$repo_path"
repo_basename="${repo_path##*/}"
current_root=$(git rev-parse --show-toplevel 2>/dev/null || true)

# Match an origin URL against a `<owner>/<repo>` or nested path, host-agnostic
# so SSH and HTTPS clones of the same project both match.
remote_matches() {
  local url="$1" target="$2"
  [[ "$url" == *"/${target}.git" || "$url" == *"/${target}" \
     || "$url" == *":${target}.git" || "$url" == *":${target}" ]]
}

resolved_dir=""

# 1. Already standing in a clone of this URL (any path).
if [[ -n "$current_root" ]]; then
  cur_url=$(git -C "$current_root" remote get-url origin 2>/dev/null || true)
  if remote_matches "$cur_url" "$repo_path"; then
    resolved_dir="$current_root"
  fi
fi

# 2. fd-search under each known code root in priority order. Bounded depth
# keeps the walk fast on deep trees; the URL check filters false positives if
# multiple dirs share the basename.
if [[ -z "$resolved_dir" ]] && command -v fd >/dev/null; then
  search_roots=("${WORK:-}" "${PROJECTS:-}" "${CODE:-}" "${LEARN:-}")
  for root in "${search_roots[@]}"; do
    [[ -n "$root" && -d "$root" ]] || continue
    while IFS= read -r candidate; do
      [[ -d "$candidate/.git" ]] || continue
      cand_url=$(git -C "$candidate" remote get-url origin 2>/dev/null || true)
      [[ -n "$cand_url" ]] || continue
      if remote_matches "$cand_url" "$repo_path"; then
        resolved_dir="$candidate"
        break 2
      fi
    done < <(fd --type d --hidden --no-ignore --absolute-path --max-depth 6 \
                "^${repo_basename}$" "$root" 2>/dev/null || true)
  done
fi

# 3. Canonical $REPOS path.
if [[ -z "$resolved_dir" && -d "$canonical_dir/.git" ]]; then
  resolved_dir="$canonical_dir"
fi

just_cloned=0
if [[ -n "$resolved_dir" ]]; then
  [[ "$PWD" == "$resolved_dir" ]] || cd "$resolved_dir"
else
  # _clone runs without strict mode and uses unquoted $REPOS / nullable vars,
  # so relax our flags around the source call.
  clone_helper="$HOME/.local/share/scripts/utilities/stuff-git/_clone"
  [[ -f "$clone_helper" ]] || { echo "h: missing helper \`$clone_helper\`" >&2; exit 4; }
  set +e +u +o pipefail
  # shellcheck source=/dev/null
  source "$clone_helper" "$repo_url"
  set -e -u -o pipefail
  git rev-parse --git-dir >/dev/null 2>&1 \
    || { echo "h: clone failed; cwd \`$PWD\` is not a git repo" >&2; exit 4; }
  just_cloned=1
fi

# Always refresh refs when reusing an existing clone; a fresh clone is current.
if (( ! just_cloned )); then
  git fetch --quiet origin 2>/dev/null || true
fi

detect_base() {
  local b
  b=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null || true)
  b="${b#origin/}"
  if [[ -z "$b" ]]; then
    for cand in main master; do
      git rev-parse --verify --quiet "origin/$cand" >/dev/null 2>&1 \
        && { b="$cand"; break; }
    done
  fi
  echo "${b:-main}"
}

if [[ -z "$pr_num" ]]; then
  base=$(detect_base)
  exec hunk diff "origin/$base"
fi

command -v jq >/dev/null || { echo "h: \`jq\` not on PATH" >&2; exit 127; }

case "$forge" in
  github)
    command -v gh >/dev/null || { echo "h: \`gh\` not on PATH" >&2; exit 127; }
    pr_json=$(gh pr view --repo "$repo_path" "$pr_num" --json baseRefName,headRefOid 2>&1) \
      || { printf 'h: gh pr view failed\n%s\n' "$pr_json" >&2; exit 2; }
    { IFS=$'\t' read -r base head_sha || true; } < <(
      jq -r '[.baseRefName, .headRefOid] | @tsv' <<<"$pr_json"
    )
    ref_name="pr/$pr_num"
    fetch_spec="pull/$pr_num/head:refs/remotes/origin/$ref_name"
    ;;
  gitlab)
    command -v glab >/dev/null || { echo "h: \`glab\` not on PATH" >&2; exit 127; }
    mr_json=$(glab mr view --repo "$repo_path" "$pr_num" --output json 2>&1) \
      || { printf 'h: glab mr view failed\n%s\n' "$mr_json" >&2; exit 2; }
    { IFS=$'\t' read -r base head_sha || true; } < <(
      jq -r '[.target_branch, (.sha // .diff_refs.head_sha // "")] | @tsv' <<<"$mr_json"
    )
    ref_name="mr/$pr_num"
    fetch_spec="merge-requests/$pr_num/head:refs/remotes/origin/$ref_name"
    ;;
esac

[[ "$head_sha" =~ ^[0-9a-f]{40}$ ]] \
  || { echo "h: invalid head SHA \`$head_sha\`" >&2; exit 2; }

# Fast path: head commit already local (warm clone) so we can name the ref
# without a fetch.
if git rev-parse --verify "${head_sha}^{commit}" >/dev/null 2>&1; then
  git update-ref "refs/remotes/origin/$ref_name" "$head_sha"
else
  git fetch --quiet origin "$fetch_spec" \
    || { echo "h: failed to fetch $fetch_spec" >&2; exit 3; }
fi

if ! git rev-parse --verify "origin/$base" >/dev/null 2>&1; then
  git fetch --quiet origin "$base" \
    || { echo "h: failed to fetch base \`$base\`" >&2; exit 3; }
fi

exec hunk diff "origin/${base}...origin/${ref_name}"
