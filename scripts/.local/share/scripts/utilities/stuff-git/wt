#!/usr/bin/env bash
# wt — git worktree helper using ~/worktrees/<repo>/<branch> layout.
#
# Subcommands:
#   wt new <branch> [base]   create ~/worktrees/<repo>/<branch> tracking <base>
#                            (defaults to creating a new branch off HEAD)
#   wt list                  list every worktree of the current repo
#   wt rm <branch>           remove the worktree for <branch>
#   wt clean [--force]       remove every worktree of the current repo except
#                            the one you're standing in. With --force, drop
#                            uncommitted changes too.
#   wt pick                  fzf-pick a worktree and print its path (used by
#                            the `wt()` shell wrapper in ~/.config/.aliases
#                            to do the `cd` for you). Standalone callers can
#                            do `cd $(wt pick)`.
#   wt root                  print the worktrees-root for the current repo
#                            (~/worktrees/<reponame>)
#   wt help                  show this help
#
# With no subcommand the script behaves like `wt pick` — prints the chosen
# worktree path on stdout. The shell wrapper turns that into a `cd`.

set -euo pipefail

WORKTREE_HOME="${WT_HOME:-$HOME/worktrees}"

die() {
  printf 'wt: %s\n' "$*" >&2
  exit 1
}

require_git_repo() {
  git rev-parse --show-toplevel >/dev/null 2>&1 \
    || die "not in a git repository"
}

# Resolve the repo's logical name from the *main* worktree's directory name,
# so `wt` from inside a worktree still groups under the same parent.
canonical_repo_name() {
  local main_root
  main_root="$(git worktree list --porcelain \
    | awk '/^worktree / { print $2; exit }')"
  basename "$main_root"
}

worktrees_root() {
  printf '%s/%s' "$WORKTREE_HOME" "$(canonical_repo_name)"
}

main_worktree_path() {
  git worktree list --porcelain | awk '/^worktree / { print $2; exit }'
}

print_help() {
  cat <<'EOF'
wt — git worktree helper

Usage:
  wt                       same as `wt pick` — print fzf-selected path
  wt new <branch> [base]   create ~/worktrees/<repo>/<branch>
  wt list                  list worktrees of the current repo
  wt rm <branch>           remove one worktree
  wt clean [--force]       remove every non-main, non-current worktree
  wt pick                  print the fzf-selected worktree path
  wt root                  print the worktrees-root for the current repo
  wt help                  show this help

Layout: ~/worktrees/<reponame>/<branchname>.
Override the parent dir with WT_HOME=… in the environment.
EOF
}

cmd_root() {
  require_git_repo
  printf '%s\n' "$(worktrees_root)"
}

cmd_list() {
  require_git_repo
  git worktree list
}

cmd_pick() {
  require_git_repo
  command -v fzf >/dev/null 2>&1 || die "fzf not installed"

  local selection
  # Tab-separated columns: branch (or HEAD), path. fzf shows the branch first
  # so muscle memory matches `git worktree list`. The trailing path is what
  # callers actually want, so awk strips it on the way out.
  selection="$(
    git worktree list --porcelain \
      | awk '
          $1 == "worktree" { wt = $2; branch = ""; next }
          $1 == "branch"   { sub(/^refs\/heads\//, "", $2); branch = $2 }
          $1 == "detached" { branch = "(detached)" }
          /^$/ && wt {
            printf "%s\t%s\n", branch ? branch : "(no branch)", wt
            wt = ""; branch = ""
          }
          END {
            if (wt) printf "%s\t%s\n", branch ? branch : "(no branch)", wt
          }
        ' \
      | fzf --delimiter=$'\t' --with-nth=1,2 \
            --height=80% --reverse \
            --prompt='worktree> ' \
            --preview='git -C {2} log --color=always --format="%C(auto)%h%d%C(reset)%n  %s" -25' \
            --preview-window='right:60%:wrap'
  )" || return 1

  [[ -z "$selection" ]] && return 1
  printf '%s\n' "${selection##*$'\t'}"
}

cmd_new() {
  require_git_repo
  local branch="${1:-}"
  local base="${2:-}"
  [[ -n "$branch" ]] || die "usage: wt new <branch> [base]"

  local target
  target="$(worktrees_root)/$branch"

  mkdir -p "$(dirname "$target")"

  if git show-ref --verify --quiet "refs/heads/$branch"; then
    git worktree add "$target" "$branch"
  elif [[ -n "$base" ]]; then
    git worktree add -b "$branch" "$target" "$base"
  else
    git worktree add -b "$branch" "$target"
  fi
}

cmd_rm() {
  require_git_repo
  local branch="${1:-}"
  [[ -n "$branch" ]] || die "usage: wt rm <branch>"

  local target
  target="$(worktrees_root)/$branch"

  [[ -d "$target" ]] || die "no worktree at $target"
  git worktree remove "$target"
  rmdir "$(dirname "$target")" 2>/dev/null || true
}

cmd_clean() {
  require_git_repo
  local force=0
  if [[ "${1:-}" == "--force" || "${1:-}" == "-f" ]]; then
    force=1
  fi

  local current_root main_root removed=0
  current_root="$(git rev-parse --show-toplevel)"
  main_root="$(main_worktree_path)"

  while IFS= read -r line; do
    [[ "$line" =~ ^worktree[[:space:]](.+)$ ]] || continue
    local wt="${BASH_REMATCH[1]}"
    [[ "$wt" == "$main_root" ]] && continue
    [[ "$wt" == "$current_root" ]] && continue

    if (( force )); then
      git worktree remove --force "$wt" && removed=$((removed + 1))
    else
      git worktree remove "$wt" && removed=$((removed + 1))
    fi
  done < <(git worktree list --porcelain)

  # Drop the now-empty parent dir under ~/worktrees/<repo>.
  rmdir "$(worktrees_root)" 2>/dev/null || true

  printf 'wt: removed %d worktree(s)\n' "$removed"
}

main() {
  local sub="${1:-pick}"
  shift || true
  case "$sub" in
    new) cmd_new "$@" ;;
    list|ls) cmd_list "$@" ;;
    rm|remove) cmd_rm "$@" ;;
    clean) cmd_clean "$@" ;;
    pick) cmd_pick "$@" ;;
    root) cmd_root "$@" ;;
    -h|--help|help) print_help ;;
    *) die "unknown subcommand: $sub (try 'wt help')" ;;
  esac
}

main "$@"
