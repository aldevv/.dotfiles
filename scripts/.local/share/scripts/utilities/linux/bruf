#!/bin/bash

# Check if bruno CLI is installed, install if not
if ! command -v bru &> /dev/null; then
    echo "Bruno CLI not found. Installing @usebruno/cli..."
    npm install -g @usebruno/cli
fi

# Find bruno collection root by locating bruno.json
# Prefer git root if available, otherwise use current directory
search_root=$(git rev-parse --show-toplevel 2>/dev/null) || search_root=$(pwd)

# Use find to locate bruno.json
bruno_json=$(find "$search_root" -name "bruno.json" -type f | head -1)

if [ -z "$bruno_json" ]; then
    echo "Error: bruno.json not found in $search_root"
    exit 1
fi

bruno_root=$(dirname "$bruno_json")

history_file="$HOME/.cache/bruf-history"
mkdir -p "$HOME/.cache"

# Get all .bru files in collection
all_files=$(find "$bruno_root" -name "*.bru" -type f -printf '%P\n')

# Sort files by usage: recently used first, then unused
if [ -f "$history_file" ]; then
    # Recently used files in reverse order (most recent first), duplicates removed
    used_files=$(tac "$history_file" | awk '!seen[$0]++')

    # Find files never run before (not in history)
    unused_files=$(comm -23 <(sort <<< "$all_files") <(sort "$history_file" | uniq))

    # Combine lists: used first, then unused
    sorted_files=$(printf "%s\n%s" "$used_files" "$unused_files" | grep -v '^$')
else
    sorted_files="$all_files"
fi

# Use fzf to select (use bat if available for syntax highlighting)
preview_cmd="cat -- {}"
if command -v bat &> /dev/null; then
    preview_cmd="bat --color=always --language yaml -- {}"
fi
selected=$(echo "$sorted_files" | \
    fzf --preview "( cd '$bruno_root' && $preview_cmd )")

if [ -z "$selected" ]; then
    exit 1
fi

# Log the selection to history
echo "$selected" >> "$history_file"

# Run test from bruno collection root and extract response data
# Skip first 17 lines of output and remove summary message
(cd "$bruno_root" && \
    bru run --env local "$selected" --reporter-json /dev/stdout 2>&1 | \
    tail -n +17 | \
    sed 's/Wrote json results to \/dev\/stdout$//' | \
    jq '.[0].results[0].response.data')

