#!/usr/bin/env bash
# okta-verify-watch - Watch for Okta Verify password dialog and auto-fill it
# Requires: gpg, cliclick (brew install cliclick)
# Mac password stored encrypted at: ~/.mac_password.gpg
# Create it with: echo -n 'your_mac_password' | gpg --encrypt --recipient your@email.com -o ~/.mac_password.gpg

set -euo pipefail

ENCRYPTED_PASS="$HOME/.mac_password.gpg"

if [[ ! -f "$ENCRYPTED_PASS" ]]; then
    echo "Error: encrypted password not found at $ENCRYPTED_PASS"
    echo "Create it with: echo -n 'your_mac_password' | gpg --encrypt --recipient your@email.com -o $ENCRYPTED_PASS"
    exit 1
fi

if ! command -v cliclick &>/dev/null; then
    echo "Error: cliclick not found. Install with: brew install cliclick"
    exit 1
fi

PASSWORD=$(gpg --quiet --decrypt "$ENCRYPTED_PASS")

echo "Watching for Okta Verify dialog..."

while ! pgrep -x "Okta Verify" > /dev/null 2>&1; do
    sleep 0.5
done

# Give the dialog time to render and focus the password field
sleep 5

cliclick t:"$PASSWORD"
sleep 1
cliclick kp:return

unset PASSWORD
echo "Done."
